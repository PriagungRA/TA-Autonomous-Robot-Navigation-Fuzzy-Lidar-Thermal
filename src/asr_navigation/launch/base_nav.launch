<launch>
  <arg name="map_file" default="$(find asr_navigation)/maps/grit_1.yaml"/>
  <!-- <arg name="db_path"  default="~/rtab_maps/map_5_12_2025_fs1.db"/> -->

  <arg name="addr" default="" />
  <arg name="use_standard_msgs" default="true" />

  <include file="$(find rplidar_ros)/launch/rplidar_a2m8.launch" />

  <node pkg="tf" type="static_transform_publisher" name="base_to_laser" args="0.12 0 0 3.14159 0 0 base_link laser 10" />
  <node pkg="tf" type="static_transform_publisher" name="base_to_camera" args="0.20 0 0.35 0 0 0 base_link camera_link 10" />

  <node pkg="imu_filter_madgwick" type="imu_filter_node" name="imu_filter_madgwick" output="screen">
    <param name="use_mag" value="false"/>
    <param name="publish_tf" value="false"/>
    <param name="world_frame" value="enu"/>
    <remap from="/imu/data_raw" to="/camera/imu"/> 
    <remap from="/imu/data" to="/imu/data"/>
  </node>

  <node pkg="laser_filters" type="scan_to_scan_filter_chain" name="laser_filter">
    <remap from="scan" to="/scan" />
    <remap from="scan_filtered" to="/scan_filtered" />
    <rosparam command="load" file="$(find rtabmap_launch)/launch/robot_filter.yaml" />
  </node>

  <node pkg="main_controller" type="robot_comhardware_node" name="comhardware_node" output="log"/>
  
  <node pkg="ds4_driver" type="ds4_driver_node.py" name="ds4_driver" >
      <rosparam command="load" file="$(find ds4_driver)/config/params.yaml" />
      <param name="device_addr" value="$(arg addr)" />
      <param name="use_standard_msgs" value="$(arg use_standard_msgs)" />
  </node>
  <!-- <node pkg="main_controller" type="robot_node" name="robot_node" /> -->

  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)">
    <param name="frame_id" value="map"/>
  </node>

  <node pkg="rtabmap_odom" type="icp_odometry" name="icp_odometry" output="screen">
    
    <remap from="scan"          to="/scan_filtered"/>
    <remap from="odom"          to="/odom"/>
    <remap from="imu"           to="/imu/data"/>

    <param name="frame_id"      value="base_link"/>
    <param name="odom_frame_id" value="odom"/>

    <param name="wait_imu_to_init"    value="false"/> 
    <param name="approx_sync"         value="true"/>
    <param name="queue_size"          value="50"/>

    <param name="Odom/GuessMotion"    value="true"/>
    <param name="Odom/ResetCountdown" value="1"/>

    <param name="Icp/PointToPlane"    value="false"/>
    <param name="Icp/VoxelSize"       value="0.05"/>
    <param name="Icp/MaxTranslation"  value="0.5"/>
    <param name="Icp/MaxCorrespondenceDistance" value="0.2"/>
    <param name="Icp/CorrespondenceRatio"       value="0.1"/>
    <param name="Icp/Iterations"      value="30"/>
  </node>

  <include file="$(find main_controller)/launch/amcl.launch">
    <arg name="scan_topic" value="/scan_filtered"/>
  </include>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    
    <param name="base_global_planner" value="navfn/NavfnROS"/>
    <param name="base_local_planner"  value="base_local_planner/TrajectoryPlannerROS"/>

    <param name="controller_frequency" value="10.0" />
    <param name="planner_frequency" value="2.0" />

    <rosparam file="$(find asr_navigation)/params/common_costmap.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find asr_navigation)/params/common_costmap.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find asr_navigation)/params/local_costmap.yaml"  command="load" />
    <rosparam file="$(find asr_navigation)/params/global_costmap.yaml" command="load" />
    
    <rosparam file="$(find asr_navigation)/params/base_local_planner.yaml" command="load" />

    <remap from="cmd_vel" to="/cmd_vel"/>
    <remap from="odom" to="/odom"/> 
  </node>

  <node pkg="asr_navigation" type="convert.py" name="convert" />

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find asr_navigation)/params/amcl.rviz" />

</launch>